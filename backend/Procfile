# Railway / Heroku Procfile (Nixpacks / Buildpack-Deploy ohne Docker)
# Docker-Deploy: CMD kommt aus dem Dockerfile (PORT wird von Railway gesetzt).
web: uvicorn app.main:app --host 0.0.0.0 --port $PORT --workers 2 --proxy-headers --forwarded-allow-ips '*'
worker: celery -A app.jobs.celery_app:celery_app worker --loglevel=info --concurrency=2 --queues=analysis,webhooks,default

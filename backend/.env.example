# ── App ────────────────────────────────────────────────────────────────────────
# Railway / Produktion: APP_ENV=production, DEBUG=false, nur https-Origins (Security-Check).
APP_ENV=development
DEBUG=true
# Inkl. Produktions-Domain; Vercel (*.vercel.app) erlaubt das Backend zusätzlich per allow_origin_regex in main.py
ALLOWED_ORIGINS=["http://localhost:3000","https://characterwebsites.com","https://characterwebsites.vercel.app"]

# ── Supabase ────────────────────────────────────────────────────────────────────
SUPABASE_URL=https://yeiizwkinffsjtfmvjio.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SERVICE_ROLE_KEY

# ── Redis / Celery ────────────────────────────────────────────────────────────
# Lokal mit docker-compose (Redis hat --requirepass, Standard: devredispass):
#   URL-Form: redis://:PASSWORT@localhost:6379/DBINDEX
# Railway: Plugin-URL referenzieren, /0 /1 /2 (Passwort steckt meist schon in der URL).
REDIS_URL=redis://:devredispass@localhost:6379/0
CELERY_BROKER_URL=redis://:devredispass@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:devredispass@localhost:6379/2

# ── Claude AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_KEY
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ── Claude Rate Limiting (Omi-Massen-Updates) ─────────────────────────────────
# Per-User Debounce: Omi-Bursts werden zu 1 Claude-Call zusammengefasst.
CLAUDE_DEBOUNCE_SECONDS=600
# Hartes Cap pro User pro UTC-Tag (Kostenschutz).
CLAUDE_MAX_PER_USER_PER_DAY=30
# Globale RPM-Drosselung (alle Worker zusammen) gegen Anthropic-API-Limits.
CLAUDE_GLOBAL_RPM=30
CLAUDE_GLOBAL_TOKEN_TIMEOUT_SECONDS=60

# ── Frontend Webhook ───────────────────────────────────────────────────────────
FRONTEND_ISR_WEBHOOK_URL=https://characterwebsites.com/api/revalidate
FRONTEND_ISR_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET

# Optional: Ziel nach Klick auf Supabase-Bestätigungslink (muss in Supabase „Redirect URLs“ stehen)
# AUTH_EMAIL_REDIRECT_URL=https://characterwebsites.vercel.app

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=true
ALLOWED_ORIGINS=["http://localhost:3000","https://characterwebsites.com"]

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://cw_app:secret@localhost:5432/characterwebsites
DATABASE_URL_SYNC=postgresql://cw_app:secret@localhost:5432/characterwebsites

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_SECURE_RANDOM_64_CHAR_HEX
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── S3 ─────────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=characterwebsites-uploads
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_KEY
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_SECRET
# S3_ENDPOINT_URL=http://localhost:9000  # Uncomment for MinIO

# ── Claude AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_KEY
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_MAX_TOKENS=4096

# ── Frontend Webhook ───────────────────────────────────────────────────────────
FRONTEND_ISR_WEBHOOK_URL=https://characterwebsites.com/api/revalidate
FRONTEND_ISR_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET
